<% layout("/layouts/boilerplate") %>

    <div class="content">

        <!-- Page Heading -->
        <header class="page-header">
            <h1>Civic Issues Dashboard</h1>
            <p>Track, prioritize, and resolve community problems.</p>
        </header>
        <!-- Filter Section -->
        <section class="filters">
            <input type="text" class="search-bar" placeholder="Search issues by title, description, or location..." />
            <div class="filter-controls">
                <select>
                    <option>All Categories</option>
                    <option>Garbage</option>
                    <option>Pothole</option>
                    <option>Streetlight</option>
                    <option>Waterlogging</option>
                </select>

                <select>
                    <option>All Zones</option>
                    <option>North Zone</option>
                    <option>South Zone</option>
                    <option>East Zone</option>
                    <option>West Zone</option>
                </select>

                <select>
                    <option>All Status</option>
                    <option>Pending</option>
                    <option>In Progress</option>
                    <option>Resolved</option>
                </select>

                <select>
                    <option>All Priority</option>
                    <option>High</option>
                    <option>Medium</option>
                    <option>Low</option>
                </select>

                <select>
                    <option>Latest</option>
                    <option>Oldest</option>
                </select>
                <button class="reset-btn">Reset Filters</button>
            </div>
        </section>

