<% layout("/layouts/boilerplate") %>
<body>
    <div class="container mt-4">
        <!-- Profile Header -->
        <div class="profile-title-section mb-4">
            <h1 class="profile-main-title">My Profile</h1>
            <p class="profile-subtitle">Manage your account information and view your activity</p>
        </div>

        <div class="row">
            <!-- Left Column - Profile Info, Badges, and Achievement Goals -->
            <div class="col-lg-4 col-md-6 mb-4">
                <!-- Profile Card -->
                <div class="profile-card">
                    <div class="profile-avatar-section">
                        <div class="avatar-placeholder">
                            <i class="fas fa-camera"></i>
                        </div>
                        <div class="profile-info">
                            <h3 class="profile-email">anushka@gmail.com</h3>
                            <span class="profile-badge">citizen</span>
                            <div class="reputation">
                                <i class="fas fa-star"></i>
                                <span>0 reputation</span>
                            </div>
                            <div class="join-date">
                                <i class="fas fa-calendar-alt"></i>
                                <span>Joined 15/03/2025</span>
                            </div>
                        </div>
                    </div>
                    <button class="btn btn-edit-profile">
                        <i class="fas fa-edit"></i> Edit Profile
                    </button>
                </div>

                <!-- Badges Section -->
                <div class="badges-section mt-4">
                    <h3 class="section-title">
                        <i class="fas fa-trophy"></i> Badges
                    </h3>
                    <div class="badges-container">
                        <div class="no-badges">
                            <div class="badge-placeholder">
                                <i class="fas fa-award"></i>
                            </div>
                            <p class="no-badges-text">No badges earned yet</p>
                            <p class="badges-hint">Start reporting issues to earn badges!</p>
                        </div>
                    </div>
                </div>

                <!-- Achievement Goals Under Badges -->
                <div class="achievement-goals mt-4">
                    <h3 class="section-title">
                        <i class="fas fa-bullseye"></i> Achievement Goals
                    </h3>
                    <div class="goal-card mb-3 text-center">
                        <div class="goal-icon mb-2"><i class="fas fa-flag"></i></div>
                        <h5>First Reporter</h5>
                        <p>Report your first civic issue</p>
                        <div class="progress mb-2">
                            <div class="progress-bar" style="width: 0%"></div>
                        </div>
                        <small>0/1 completed</small>
                    </div>

                    <div class="goal-card mb-3 text-center">
                        <div class="goal-icon mb-2"><i class="fas fa-thumbs-up"></i></div>
                        <h5>Community Supporter</h5>
                        <p>Vote on 10 different issues</p>
                        <div class="progress mb-2">
                            <div class="progress-bar" style="width: 30%"></div>
                        </div>
                        <small>3/10 completed</small>
                    </div>

                    <div class="goal-card text-center">
                        <div class="goal-icon mb-2"><i class="fas fa-comments"></i></div>
                        <h5>Active Participant</h5>
                        <p>Make 5 helpful comments</p>
                        <div class="progress mb-2">
                            <div class="progress-bar" style="width: 20%"></div>
                        </div>
                        <small>1/5 completed</small>
                    </div>
                </div>
            </div>

            <!-- Right Column - Stats, Timeline, and Activity -->
            <div class="col-lg-8 col-md-6">
                <!-- Stats Cards -->
                <div class="row mb-4">
                    <div class="col-sm-6 col-lg-3 mb-3">
                        <div class="stat-card issues-created">
                            <div class="stat-icon">
                                <i class="fa-solid fa-triangle-exclamation"></i>
                            </div>
                            <div class="stat-number">2</div>
                            <div class="stat-label">Issues Created</div>
                        </div>
                    </div>
                    <div class="col-sm-6 col-lg-3 mb-3">
                        <div class="stat-card issues-resolved">
                            <div class="stat-icon">
                                <i class="fas fa-check-circle"></i>
                            </div>
                            <div class="stat-number">1</div>
                            <div class="stat-label">Issues Resolved</div>
                        </div>
                    </div>
                    <div class="col-sm-6 col-lg-3 mb-3">
                        <div class="stat-card comments-made">
                            <div class="stat-icon">
                                <i class="fas fa-comments"></i>
                            </div>
                            <div class="stat-number">0</div>
                            <div class="stat-label">Comments Made</div>
                        </div>
                    </div>
                    <div class="col-sm-6 col-lg-3 mb-3">
                        <div class="stat-card votes-cast">
                            <div class="stat-icon">
                                <i class="fas fa-chart-line"></i>
                            </div>
                            <div class="stat-number">3</div>
                            <div class="stat-label">Votes Cast</div>
                        </div>
                    </div>
                </div>

                <!-- Quick Actions (Track Complaint & Emergency Helplines) -->
                <div class="quick-actions">
                    <div class="card">
                        <div class="quick-action">
                            <div class="quick-action-icon green">
                                <i class="fas fa-search"></i>
                            </div>
                            <div class="quick-action-content">
                                <h6>Track Complaint Status</h6>
                                <p>Monitor your reports progress</p>
                                <button class="quick-action-btn green" onclick="showTrackingModal()">
                                    Real-time Updates
                                </button>
                            </div>
                        </div>
                    </div>
                    <div class="card">
                        <div class="quick-action">
                            <div class="quick-action-icon red">
                                <i class="fas fa-phone"></i>
                            </div>
                            <div class="quick-action-content">
                                <h6>Emergency Helplines</h6>
                                <p>Important contact numbers</p>
                                <button class="quick-action-btn red" onclick="showEmergencyModal()">
                                    24/7 Available
                                </button>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Status Timeline -->
                <div class="card mb-4">
                    <div class="card-body">
                        <div class="section-title">
                            <i class="fas fa-clock"></i> Status Timeline
                        </div>
                        <div class="timeline-container">
                            <div class="timeline-line"></div>
                            
                            <div class="timeline-item">
                                <div class="timeline-dot completed">
                                    <i class="fas fa-check"></i>
                                </div>
                                <div class="timeline-content">
                                    <h6>Registered</h6>
                                    <div class="timeline-date">Processing...</div>
                                    <div class="timeline-id">Issue ID: ISSUE-002</div>
                                    <div class="timeline-desc">Your complaint has been successfully registered in the system</div>
                                </div>
                            </div>

                            <div class="timeline-item">
                                <div class="timeline-dot completed">
                                    <i class="fas fa-check"></i>
                                </div>
                                <div class="timeline-content">
                                    <h6>Assigned</h6>
                                    <div class="timeline-date">20/08/2025, 6:36:18 PM</div>
                                    <div class="timeline-desc">Auto-routed based on issue type: Pothole roads</div>
                                    <div class="timeline-meta">
                                        <i class="fas fa-map-marker-alt"></i>
                                        <span>MG Road / Municipal Corporation</span>
                                    </div>
                                </div>
                            </div>

                            <div class="timeline-item">
                                <div class="timeline-dot active">
                                    <i class="fas fa-cog"></i>
                                </div>
                                <div class="timeline-content">
                                    <h6>In Progress</h6>
                                    <div class="timeline-date">21/08/2025, 5:57:43 PM</div>
                                    <div class="timeline-desc">Status updated to In-Progress</div>
                                    <div class="timeline-meta">
                                        <i class="fas fa-user"></i>
                                        <span>Aditya ( Helper )</span>
                                    </div>
                                    <div class="contact-info">
                                        <span class="contact-id">Contact: 1800000018</span>
                                        <button class="call-btn" onclick="callHelper()">
                                            <i class="fas fa-phone"></i> Call
                                        </button>
                                    </div>
                                </div>
                            </div>

                            <div class="timeline-item">
                                <div class="timeline-dot pending">
                                    <i class="fas fa-circle"></i>
                                </div>
                                <div class="timeline-content">
                                    <h6>Resolved</h6>
                                    <div class="timeline-date">Pending</div>
                                    <div class="timeline-desc">Issue will be marked as resolved once completed</div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Activity Summary Under Timeline -->
                <div class="activity-summary">
                    <h3 class="section-title">
                        <i class="fas fa-chart-bar"></i> Activity Summary
                    </h3>
                    <div class="activity-list">
                        <div class="activity-item">
                            <div class="activity-label">Total Issues Created</div>
                            <div class="activity-value">2</div>
                        </div>
                        <div class="activity-item">
                            <div class="activity-label">Issues Resolved</div>
                            <div class="activity-value success">1</div>
                        </div>
                        <div class="activity-item">
                            <div class="activity-label">Comments Made</div>
                            <div class="activity-value">0</div>
                        </div>
                        <div class="activity-item">
                            <div class="activity-label">Votes Cast</div>
                            <div class="activity-value">3</div>
                        </div>
                        <div class="activity-item">
                            <div class="activity-label">Badges Earned</div>
                            <div class="activity-value">0</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Track Complaint Modal -->
    <div class="modal fade" id="trackComplaintModal" tabindex="-1">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">
                        <i class="fas fa-search me-2"></i>Track Complaint Status
                    </h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="complaint-search">
                        <input type="text" placeholder="Enter complaint ID or reference number" id="complaintSearchInput">
                        <button onclick="searchComplaint()">
                            <i class="fas fa-search"></i> Search
                        </button>
                    </div>
                    
                    <h6 class="mb-3">Your Recent Complaints</h6>
                    <div class="complaint-item">
                        <div>
                            <div class="complaint-id">ISSUE-002</div>
                            <div class="complaint-title">Pothole near MG Road Bus Stop</div>
                            <div class="complaint-location">    
                                <i class="fas fa-map-marker-alt"></i>
                                MG Road, Delhi
                            </div>
                        </div>
                        <div style="text-align: right;">
                            <div class="status-badge in-progress">In Progress</div>
                            <div style="font-size: 0.8rem; color: #666; margin-top: 4px;">Aug 21, 2025</div>
                        </div>
                    </div>
                    
                    <div class="complaint-item">
                        <div>
                            <div class="complaint-id">ISSUE-003</div>
                            <div class="complaint-title">Waterlogging after Heavy Rainfall</div>
                            <div class="complaint-location">
                                <i class="fas fa-map-marker-alt"></i>
                                MG Road, Delhi
                            </div>
                        </div>
                        <div style="text-align: right;">
                            <div class="status-badge resolved">Resolved</div>
                            <div style="font-size: 0.8rem; color: #666; margin-top: 4px;">Aug 20, 2025</div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                </div>
            </div>
        </div>
    </div>

    <!-- Emergency Helplines Modal -->
    <div class="modal fade" id="emergencyModal" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header" style="background-color: #f44336; color: white;">
                    <h5 class="modal-title">
                        <i class="fas fa-exclamation-triangle me-2"></i>Emergency Helplines
                    </h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="alert alert-warning" style="background: #fff3cd; border: none; border-left: 4px solid #ffc107;">
                        <i class="fas fa-info-circle me-2"></i>
                        <strong>24/7 Available</strong> - These numbers are available round the clock
                    </div>
                    
                    <div class="helpline-item">
                        <div class="helpline-icon emergency">
                            <i class="fas fa-ambulance"></i>
                        </div>
                        <div class="helpline-info">
                            <h6>Medical Emergency</h6>
                            <div class="helpline-number">108</div>
                        </div>
                        <button class="helpline-call-btn emergency" onclick="callEmergency('108')">
                            <i class="fas fa-phone"></i> Call
                        </button>
                    </div>
                    
                    <div class="helpline-item">
                        <div class="helpline-icon emergency">
                            <i class="fas fa-fire"></i>
                        </div>
                        <div class="helpline-info">
                            <h6>Fire Department</h6>
                            <div class="helpline-number">101</div>
                        </div>
                        <button class="helpline-call-btn emergency" onclick="callEmergency('101')">
                            <i class="fas fa-phone"></i> Call
                        </button>
                    </div>
                    
                    <div class="helpline-item">
                        <div class="helpline-icon emergency">
                            <i class="fas fa-shield-alt"></i>
                        </div>
                        <div class="helpline-info">
                            <h6>Police</h6>
                            <div class="helpline-number">100</div>
                        </div>
                        <button class="helpline-call-btn emergency" onclick="callEmergency('100')">
                            <i class="fas fa-phone"></i> Call
                        </button>
                    </div>
                    
                    <div class="helpline-item">
                        <div class="helpline-icon civic">
                            <i class="fas fa-building"></i>
                        </div>
                        <div class="helpline-info">
                            <h6>Municipal Corporation</h6>
                            <div class="helpline-number">1800-000-018</div>
                        </div>
                        <button class="helpline-call-btn" onclick="callEmergency('1800000018')">
                            <i class="fas fa-phone"></i> Call
                        </button>
                    </div>
                    
                    <div class="helpline-item">
                        <div class="helpline-icon civic">
                            <i class="fas fa-tools"></i>
                        </div>
                        <div class="helpline-info">
                            <h6>Public Works Department</h6>
                            <div class="helpline-number">1800-233-4567</div>
                        </div>
                        <button class="helpline-call-btn" onclick="callEmergency('18002334567')">
                            <i class="fas fa-phone"></i> Call
                        </button>
                    </div>
                    
                    <div class="helpline-item">
                        <div class="helpline-icon civic">
                            <i class="fas fa-lightbulb"></i>
                        </div>
                        <div class="helpline-info">
                            <h6>Electricity Board</h6>
                            <div class="helpline-number">1800-345-6789</div>
                        </div>
                        <button class="helpline-call-btn" onclick="callEmergency('18003456789')">
                            <i class="fas fa-phone"></i> Call
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Edit Profile Modal -->
    <div class="modal fade" id="editProfileModal" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Edit Profile</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <form>
                        <div class="mb-3">
                            <label class="form-label">Profile Photo</label>
                            <div class="profile-photo-upload">
                                <div class="photo-preview">
                                    <i class="fas fa-user"></i>
                                </div>
                                <input type="file" class="form-control" accept="image/*">
                            </div>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Full Name</label>
                            <input type="text" class="form-control" placeholder="Enter your full name">
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Email Address</label>
                            <input type="email" class="form-control" value="anushka@gmail.com">
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Phone Number</label>
                            <input type="tel" class="form-control" placeholder="Enter your phone number">
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Location</label>
                            <input type="text" class="form-control" placeholder="Your city/area">
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Bio</label>
                            <textarea class="form-control" rows="3" placeholder="Tell us about yourself"></textarea>
                        </div>
                    </form>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="button" class="btn btn-success">Save Changes</button>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.0/js/bootstrap.bundle.min.js"></script>
    <script>
        // Interactive functionality
        document.querySelector('.btn-edit-profile').addEventListener('click', function() {
            const modal = new bootstrap.Modal(document.getElementById('editProfileModal'));
            modal.show();
        });

        // Modal functions
        function showTrackingModal() {
            const modal = new bootstrap.Modal(document.getElementById('trackComplaintModal'));
            modal.show();
        }

        function showEmergencyModal() {
            const modal = new bootstrap.Modal(document.getElementById('emergencyModal'));
            modal.show();
        }

        // Search complaint
        function searchComplaint() {
            const input = document.getElementById('complaintSearchInput');
            const searchValue = input.value.trim();
            
            if (!searchValue) {
                alert('Please enter a complaint ID or reference number');
                return;
            }

            const button = event.target;
            const originalHtml = button.innerHTML;
            button.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Searching...';
            button.disabled = true;

            setTimeout(() => {
                button.innerHTML = originalHtml;
                button.disabled = false;
                
                if (searchValue.toLowerCase().includes('grb') || searchValue.toLowerCase().includes('str')) {
                    alert('Complaint found! Details are shown in the list below.');
                } else {
                    alert('Complaint not found. Please check the ID and try again.');
                }
            }, 1500);
        }

        // Call functions
        function callHelper() {
            if (confirm('Call Aditya (Helper) at 1800000018?')) {
                alert('Initiating call to helper...');
            }
        }

        function callEmergency(number) {
            if (confirm(`Call ${number} for assistance?`)) {
                alert(`Calling ${number}...`);
            }
        }

        function reportIssue() {
            alert('Redirecting to issue reporting form...');
        }

        function browseIssues() {
            alert('Redirecting to community issues page...');
        }

        // Simulate some activity after a few seconds (for demo purposes)
        setTimeout(function() {
            // Update some stats to show interactivity
            // const statNumbers = document.querySelectorAll('.stat-number');
            // statNumbers[2].textContent = '1'; // Comments Made
            // statNumbers[3].textContent = '3'; // Votes Cast
            
            // // Update activity summary
            // const activityValues = document.querySelectorAll('.activity-value');
            // activityValues[2].textContent = '1';
            // activityValues[3].textContent = '3';
            
            // Update progress bars
            const progressBars = document.querySelectorAll('.progress-bar');
            progressBars[1].style.width = '30%';
            progressBars[2].style.width = '20%';
            
            // Update completion text
            const completionTexts = document.querySelectorAll('.goal-card small');
            completionTexts[1].textContent = '3/10 completed';
            completionTexts[2].textContent = '1/5 completed';
        }, 3000);
    </script>
</body>
</html>