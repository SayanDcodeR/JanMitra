                <!-- Stats Section -->
                <section class="stats-section">
                    <div class="container">
                        <div class="row">
                            <div class="col-md-3 col-6">
                                <div class="stat-item" onclick="showIssues('raised')">
                                    <span class="stat-number" id="raisedCount">142</span>
                                    <div class="stat-label">Issues Raised</div>
                                </div>
                            </div>
                            <div class="col-md-3 col-6">
                                <div class="stat-item" onclick="showIssues('resolved')">
                                    <span class="stat-number" id="resolvedCount">87</span>
                                    <div class="stat-label">Issues Resolved</div>
                                </div>
                            </div>
                            <div class="col-md-3 col-6">
                                <div class="stat-item" onclick="showIssues('pending')">
                                    <span class="stat-number" id="pendingCount">55</span>
                                    <div class="stat-label">Issues Pending</div>
                                </div>
                            </div>
                            <div class="col-md-3 col-6">
                                <div class="stat-item">
                                    <span class="stat-number" id="activeUsers">1,247</span>
                                    <div class="stat-label">Active Citizens</div>
                                </div>
                            </div>
                        </div>
                    </div>
                </section>

                <!-- Location Input Section -->
                <section class="location-section">
                    <div class="container">
                        <h2 class="location-title">Find Issues Near You</h2>
                        <p class="location-subtitle">Enter your location to see nearby civic issues</p>
                        <div class="location-input-group">
                            <div class="loc-search-bar">
                                <input type="text" class="search-input" id="locationInput"
                                        placeholder="Enter your area, city, or pincode">
                                <button class="search-btn" onclick="searchLocation()">
                                    <i class="fas fa-search"></i>
                                </button>
                            </div>
                            <div class="mt-3">
                                <button class="btn btn-outline-success btn-current" onclick="getUserLocation()">
                                    <i class="fas fa-location-arrow me-2"></i>Use My Current Location
                                </button>
                            </div>
                        </div>
                    </div>
                </section>

                <!-- Issues Near You Section -->
                <section class="issues-section">
                    <div class="container">
                        <h2 class="section-title">Recent Issues</h2>
                        <div class="row">
                            <div class="col-md-4">
                               <div class="home-issue-card" onclick="showIssueDetails(1)">
                                    <div class="issue-header">
                                        <h3 class="issue-title">Pothole on Main Street</h3>
                                        <span class="issue-status status-pending">PENDING</span>
                                    </div>
                                    <div class="issue-body">
                                        <div class="issue-desc">Daily commuters face accidents, vehicle damage, and long traffic jams due to the deep pothole on Main Street.</div>
                                        <p class="issue-category"><i class="fa-solid fa-triangle-exclamation"></i>Road and Transportation</p>
                                        <p class="issue-location"><i class="fas fa-map-marker-alt"></i> 1st Street, Unit 1, Bapuji Nagar, Bhubaneswar, Odisha 751009</p>
                                        <p class="issue-time"><i class="fas fa-clock"></i> 2 days ago</p>
                                    </div>

                                    <div class="issue-footer">
                                        <a href="#" class="btn-view">View Details</a>
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="home-issue-card" onclick="showIssueDetails(2)">
                                    <div class="issue-header">
                                        <h3 class="issue-title">Street Light Not Working</h3>
                                        <span class="issue-status status-inprogress">IN PROGRESS</span>
                                    </div>
                                    <div class="issue-body">
                                        <div class="issue-desc"> Street lights on Park Avenue have been non-functional for a week. Safety concern for
                                        pedestrians at night.</div>
                                        <p class="issue-category"><i class="fa-solid fa-triangle-exclamation"></i> Electricity</p>
                                        <p class="issue-location"><i class="fas fa-map-marker-alt"></i> Saheed Nagar,Odisha</p>
                                        <p class="issue-time"><i class="fas fa-clock"></i> 5 days ago</p>
                                    </div>

                                    <div class="issue-footer">
                                        <a href="#" class="btn-view">View Details</a>
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="home-issue-card" onclick="showIssueDetails(3)">
                                    <div class="issue-header">
                                        <h3 class="issue-title">Water Supply Disruption</h3>
                                        <span class="issue-status status-resolved">Resolved</span>
                                    </div>
                                    <div class="issue-body">
                                        <div class="issue-desc"> Water Supply was disrupted in residential area. Issue has been resolved by Municipal Corporation.</div>
                                        <p class="issue-category"><i class="fa-solid fa-triangle-exclamation"></i>Water</p>
                                        <p class="issue-location"><i class="fas fa-map-marker-alt"></i>KIIT, Patia,Bhubaneswar,Odisha  751024</p>
                                        <p class="issue-time"><i class="fas fa-clock"></i>29.08.2025</p>
                                    </div>
                                    <div class="issue-footer">
                                        <a href="#" class="btn-view">View Details</a>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="text-center mt-4">
                            <button class="btn btn-outline-success" onclick="loadMoreIssues()">
                                View More Issues
                            </button>
                        </div>
                    </div>
                </section>

                <!-- Issue Reporting Form Modal -->
                <div class="modal fade" id="reportModal" tabindex="-1">
                    <div class="modal-dialog modal-lg">
                        <div class="modal-content">
                            <div class="modal-header">
                                <h5 class="modal-title"><i class="fas fa-plus-circle me-2"></i>Report a Civic Issue</h5>
                                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                            </div>
                            <div class="modal-body">
                                <form id="issueForm" action="/report" method="POST">
                                    <div class="row">
                                        <div class="col-md-6 mb-3">
                                            <label class="form-label">Issue Type</label>
                                            <select class="form-select" required>
                                                <option value="">Select issue type</option>
                                                <option value="road">Road & Transportation</option>
                                                <option value="water">Water Supply</option>
                                                <option value="electricity">Electricity</option>
                                                <option value="waste">Waste Management</option>
                                                <option value="safety">Public Safety</option>
                                                <option value="other">Other</option>
                                            </select>
                                        </div>
                                        <div class="col-md-6 mb-3">
                                            <label class="form-label">Priority Level</label>
                                            <select class="form-select" name="issue[priority]" required>
                                                <option value="low">Low</option>
                                                <option value="medium">Medium</option>
                                                <option value="high">High</option>
                                                <option value="urgent">Urgent</option>
                                            </select>
                                        </div>
                                    </div>
                                    <div class="mb-3">
                                        <label class="form-label">Issue Title</label>
                                        <input type="text" name="issue[title]" class="form-control"
                                            placeholder="Brief description of the issue" required>
                                    </div>
                                    <div class="mb-3">
                                        <label class="form-label">Detailed Description</label>
                                        <textarea class="form-control" rows="4" name="issue[description]"
                                            placeholder="Provide detailed information about the issue"
                                            required></textarea>
                                    </div>
                                    <div class="mb-3">
                                        <label class="form-label">Location</label>
                                        <input type="text" class="form-control" name="issue[location]"
                                            placeholder="Exact location of the issue" required>
                                    </div>
                                    <div class="mb-5">
                                        <label class="form-label">Upload Photos (Optional)</label>
                                        <input type="file" class="form-control" name="issue[photos]" multiple
                                            accept="image/*">
                                    </div>
                                    <div class="modal-footer">
                                        <button type="button" class="btn btn-secondary"
                                            data-bs-dismiss="modal">Cancel</button>
                                        <button class="btn btn-success" onclick="submitIssue()">Submit Issue</button>
                                    </div>
                                </form>
                            </div>

                        </div>
                    </div>
                </div>

                <!-- Bootstrap JS -->
                <script
                    src="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.0/js/bootstrap.bundle.min.js"></script>

                <script src="/js/script.js"></script>
            </body>

            </html>