<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>JanMitra - Your city, Your voice, Our Responsibility</title>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.0/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>

<body>
    <!-- Hero Section -->
    <section class="hero-section">
        <div class="container">
            <h1 class="hero-title"> Your city, Your voice, <span class="highlight-green">Our Responsibility</span></h1>
            <p class="hero-subtitle">Report civic issues, track their progress, and make your community better through
                crowdsourced civic engagement</p>
            <button class="btn btn-success btn-raise-issue text-white" onclick="showReportForm()">
                <i class="fas fa-plus-circle me-2"></i>Raise Issue
            </button>
        </div>
    </section>

    <!-- Stats Section -->
    <section class="stats-section">
        <div class="container">
            <div class="row">
                <div class="col-md-3 col-6">
                    <div class="stat-item" onclick="showIssues('raised')">
                        <span class="stat-number" id="raisedCount">142</span>
                        <div class="stat-label">Issues Raised</div>
                    </div>
                </div>
                <div class="col-md-3 col-6">
                    <div class="stat-item" onclick="showIssues('resolved')">
                        <span class="stat-number" id="resolvedCount">87</span>
                        <div class="stat-label">Issues Resolved</div>
                    </div>
                </div>
                <div class="col-md-3 col-6">
                    <div class="stat-item" onclick="showIssues('pending')">
                        <span class="stat-number" id="pendingCount">55</span>
                        <div class="stat-label">Issues Pending</div>
                    </div>
                </div>
                <div class="col-md-3 col-6">
                    <div class="stat-item">
                        <span class="stat-number" id="activeUsers">1,247</span>
                        <div class="stat-label">Active Citizens</div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Location Input Section -->
    <section class="location-section">
        <div class="container">
            <h2 class="location-title">Find Issues Near You</h2>
            <p class="location-subtitle">Enter your location to see nearby civic issues</p>
            <div class="location-input-group">
                <div class="d-flex">
                    <input type="text" class="form-control form-control-lg me-2" id="locationInput"
                        placeholder="Enter your area, city, or pincode">
                    <button class="btn btn-success btn-lg" onclick="searchLocation()">
                        <i class="fas fa-search"></i>
                    </button>
                </div>
                <div class="mt-3">
                    <button class="btn btn-outline-success" onclick="getUserLocation()">
                        <i class="fas fa-location-arrow me-2"></i>Use My Current Location
                    </button>
                </div>
            </div>
        </div>
    </section>

    <!-- Issues Near You Section -->
    <section class="issues-section">
        <div class="container">
            <h2 class="section-title">Recent Issues in Your Area</h2>
            <div class="row">
                <div class="col-md-4">
                    <div class="issue-card" onclick="showIssueDetails(1)">
                        <div class="issue-status status-pending">PENDING</div>
                        <div class="issue-icon">
                            <i class="fas fa-road"></i>
                        </div>
                        <h3 class="issue-title">Pothole on Main Street</h3>
                        <p class="issue-description">
                            Large pothole causing traffic issues near Central Market. Multiple vehicles damaged. Urgent
                            repair needed.
                        </p>
                        <div class="issue-meta">
                            <small><i class="fas fa-map-marker-alt"></i> Bhubaneswar, Odisha</small>
                            <small><i class="fas fa-clock"></i> 2 days ago</small>
                        </div>
                        <div class="issue-actions">
                            <button class="btn btn-sm btn-outline-success me-2" onclick="voteIssue(1, event)">
                                <i class="fas fa-thumbs-up"></i> <span id="votes-1">23</span>
                            </button>
                            <a href="#" class="view-more">View Details</a>
                        </div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="issue-card" onclick="showIssueDetails(2)">
                        <div class="issue-status status-progress">IN PROGRESS</div>
                        <div class="issue-icon">
                            <i class="fas fa-lightbulb"></i>
                        </div>
                        <h3 class="issue-title">Street Light Not Working</h3>
                        <p class="issue-description">
                            Street lights on Park Avenue have been non-functional for a week. Safety concern for
                            pedestrians at night.
                        </p>
                        <div class="issue-meta">
                            <small><i class="fas fa-map-marker-alt"></i> Saheed Nagar</small>
                            <small><i class="fas fa-clock"></i> 5 days ago</small>
                        </div>
                        <div class="issue-actions">
                            <button class="btn btn-sm btn-outline-success me-2" onclick="voteIssue(2, event)">
                                <i class="fas fa-thumbs-up"></i> <span id="votes-2">45</span>
                            </button>
                            <a href="#" class="view-more">View Details</a>
                        </div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="issue-card" onclick="showIssueDetails(3)">
                        <div class="issue-status status-resolved">RESOLVED</div>
                        <div class="issue-icon">
                            <i class="fas fa-tint"></i>
                        </div>
                        <h3 class="issue-title">Water Supply Disruption</h3>
                        <p class="issue-description">
                            Water supply was disrupted in residential area. Issue has been resolved by municipal
                            corporation.
                        </p>
                        <div class="issue-meta">
                            <small><i class="fas fa-map-marker-alt"></i> Jaydev Vihar</small>
                            <small><i class="fas fa-clock"></i> 1 week ago</small>
                        </div>
                        <div class="issue-actions">
                            <button class="btn btn-sm btn-outline-success me-2" onclick="voteIssue(3, event)">
                                <i class="fas fa-thumbs-up"></i> <span id="votes-3">67</span>
                            </button>
                            <a href="#" class="view-more">View Details</a>
                        </div>
                    </div>
                </div>
            </div>
            <div class="text-center mt-4">
                <button class="btn btn-outline-success btn-lg" onclick="loadMoreIssues()">
                    <i class="fas fa-plus me-2"></i>Load More Issues
                </button>
            </div>
        </div>
    </section>

    <!-- Issue Reporting Form Modal -->
    <div class="modal fade" id="reportModal" tabindex="-1">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title"><i class="fas fa-plus-circle me-2"></i>Report a Civic Issue</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <form id="issueForm" action="/report" method="POST">
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Issue Type</label>
                                <select class="form-select" required>
                                    <option value="">Select issue type</option>
                                    <option value="road">Road & Transportation</option>
                                    <option value="water">Water Supply</option>
                                    <option value="electricity">Electricity</option>
                                    <option value="waste">Waste Management</option>
                                    <option value="safety">Public Safety</option>
                                    <option value="other">Other</option>
                                </select>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Priority Level</label>
                                <select class="form-select" name="issue[priority]" required>
                                    <option value="low">Low</option>
                                    <option value="medium">Medium</option>
                                    <option value="high">High</option>
                                    <option value="urgent">Urgent</option>
                                </select>
                            </div>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Issue Title</label>
                            <input type="text" name="issue[title]" class="form-control" placeholder="Brief description of the issue"
                                required>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Detailed Description</label>
                            <textarea class="form-control" rows="4" name="issue[description]"
                                placeholder="Provide detailed information about the issue" required></textarea>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Location</label>
                            <input type="text" class="form-control" name="issue[location]" placeholder="Exact location of the issue" required>
                        </div>
                        <div class="mb-5">
                            <label class="form-label">Upload Photos (Optional)</label>
                            <input type="file" class="form-control" name="issue[photos]" multiple accept="image/*">
                        </div>
                        <div class="modal-footer">
                            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                            <button class="btn btn-success" onclick="submitIssue()">Submit Issue</button>
                        </div>
                    </form>
                </div>

            </div>
        </div>
    </div>

    <!-- Quick Actions Section -->
    <section class="quick-actions">
        <div class="container">
            <div class="row text-center">
                <div class="col-md-3 col-6 mb-3">
                    <div class="action-card" onclick="showReportForm()">
                        <i class="fas fa-plus-circle"></i>
                        <h5>Report Issue</h5>
                    </div>
                </div>
                <div class="col-md-3 col-6 mb-3">
                    <div class="action-card" onclick="trackIssue()">
                        <i class="fas fa-search"></i>
                        <h5>Track Issue</h5>
                    </div>
                </div>
                <div class="col-md-3 col-6 mb-3">
                    <div class="action-card" onclick="showMap()">
                        <i class="fas fa-map"></i>
                        <h5>Issue Map</h5>
                    </div>
                </div>
                <div class="col-md-3 col-6 mb-3">
                    <div class="action-card" onclick="showLeaderboard()">
                        <i class="fas fa-trophy"></i>
                        <h5>Community</h5>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Bootstrap JS -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.0/js/bootstrap.bundle.min.js"></script>

    <script src="/js/script.js"></script>
</body>

</html>