<% layout("/layouts/boilerplate") %>

<body>
    <!-- Hero Section -->
    <section class="hero-section">
        <div class="container">
            <h1 class="hero-title"> Your city, Your voice, <span class="highlight-green">Our Responsibility</span></h1>
            <p class="hero-subtitle">Report civic issues, track their progress, and make your community better through
                crowdsourced civic engagement</p>
            <button class="btn btn-success btn-raise-issue text-white" onclick="showReportForm()">
                <i class="fas fa-plus-circle me-2"></i>Raise Issue
            </button>
        </div>
    </section>

