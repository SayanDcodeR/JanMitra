
<% layout("/layouts/boilerplate") %>
  <!-- Header -->
  <section class="about-header mt-3">
    <h1>About Code4Earth</h1>
    <p><i class="fas fa-leaf"></i> Building a cleaner, safer and greener society through technology.</p>
  </section>

  <!-- Mission / Vision / Approach -->
  <section class="about-content">
    <div class="about-card">
      <i class="fas fa-bullseye"></i>
      <h2>Our Mission</h2>
      <p>
        Code4Earth is dedicated to connecting citizens with authorities 
        to ensure accountability, transparency, and a better living environment.
      </p>
    </div>

    <div class="about-card">
      <i class="fas fa-eye"></i>
      <h2>Our Vision</h2>
      <p>
        We envision a sustainable future where technology empowers 
        communities to actively participate in civic improvement.
      </p>
    </div>

    <div class="about-card">
      <i class="fas fa-handshake"></i>
      <h2>Our Approach</h2>
      <p>
        Combining crowdsourced reporting, real-time analytics, and geospatial insights, 
        we help solve problems quickly and effectively.
      </p>
    </div>
  </section>

  <!-- Journey / Timeline -->
  <section class="journey">
    <h2>Our Journey</h2>
    <div class="timeline">
      <div class="timeline-item">
        <i class="fas fa-lightbulb"></i>
        <h3>2023 - Idea</h3>
        <p>It all started with a vision to make cities smarter and sustainable.</p>
      </div>
      <div class="timeline-item">
        <i class="fas fa-code"></i>
        <h3>2024 - Development</h3>
        <p>We built the foundation of Code4Earth and started pilot testing in local areas.</p>
      </div>
      <div class="timeline-item">
        <i class="fas fa-globe"></i>
        <h3>2025 - Expansion</h3>
        <p>Code4Earth is scaling to more cities, empowering citizens and authorities alike.</p>
      </div>
    </div>
  </section>

  <!-- Core Values -->
  <section class="values">
    <h2>Our Core Values</h2>
    <div class="values-container">
      <div class="value-card">
        <i class="fas fa-users"></i>
        <h3>Community First</h3>
        <p>People are at the heart of what we do.</p>
      </div>
      <div class="value-card">
        <i class="fas fa-shield-alt"></i>
        <h3>Transparency</h3>
        <p>Open and honest reporting for trust and accountability.</p>
      </div>
      <div class="value-card">
        <i class="fas fa-leaf"></i>
        <h3>Sustainability</h3>
        <p>Every feature is designed keeping the environment in mind.</p>
      </div>
    </div>
  </section>

  <!-- Team -->
  <section class="team-section">
    <h2>Meet Our Team</h2>
    <div class="team-container">
      <div class="team-member">
        <img src="images/avatar1.png" alt="Team Member">
        <h3>John Doe</h3>
        <p><i class="fas fa-user-tie"></i> Project Lead</p>
      </div>
      <div class="team-member">
        <img src="images/avatar2.png" alt="Team Member">
        <h3>Jane Smith</h3>
        <p><i class="fas fa-laptop-code"></i> Frontend Developer</p>
      </div>
      <div class="team-member">
        <img src="images/avatar3.png" alt="Team Member">
        <h3>Alex Brown</h3>
        <p><i class="fas fa-database"></i> Backend Developer</p>
      </div>
    </div>
  </section>

</body>

